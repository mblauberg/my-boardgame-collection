{
  "name": "my-boardgame-collection",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck:app && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:app && npm run typecheck:tools && npm run typecheck:edge",
    "typecheck:app": "tsc -p tsconfig.json --noEmit",
    "typecheck:tools": "tsc -p tsconfig.tools.json --noEmit",
    "typecheck:edge": "deno check supabase/functions/**/*.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "migrate:generate": "tsx scripts/generateSeedData.ts",
    "migrate:import": "tsx scripts/importLegacyData.ts",
    "migrate:import-bgg": "tsx scripts/importBggCsv.ts",
    "migrate:backfill-shared-tags": "tsx scripts/backfillSharedTags.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@iconify/react": "^6.0.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@supabase/supabase-js": "^2.102.1",
    "@tanstack/react-query": "^5.96.2",
    "dotenv": "^17.4.1",
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@simplewebauthn/server": "^13.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "csv-parse": "^6.2.1",
    "deno-bin": "^2.2.7",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
